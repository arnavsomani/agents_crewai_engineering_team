import unittest
from accounts import AccountManager

class TestAccountManager(unittest.TestCase):

    def setUp(self):
        self.manager = AccountManager()

    def test_register_user(self):
        result = self.manager.register_user("testuser", "password123")
        self.assertTrue(result)
        self.assertIn("testuser", self.manager.users)

    def test_register_user_existing(self):
        self.manager.register_user("testuser", "password123")
        result = self.manager.register_user("testuser", "newpassword")
        self.assertFalse(result)

    def test_login_success(self):
        self.manager.register_user("testuser", "password123")
        result = self.manager.login("testuser", "password123")
        self.assertTrue(result)

    def test_login_failure(self):
        self.manager.register_user("testuser", "password123")
        result = self.manager.login("testuser", "wrongpassword")
        self.assertFalse(result)

    def test_get_user_details(self):
        self.manager.register_user("testuser", "password123")
        details = self.manager.get_user_details("testuser")
        self.assertEqual(details['username'], "testuser")

    def test_get_nonexistent_user_details(self):
        details = self.manager.get_user_details("nonexistent")
        self.assertIsNone(details)

if __name__ == '__main__':
    unittest.main()