import unittest
from accounts import UserAccount  # Assuming 'accounts.py' defines a 'UserAccount' class

class TestUserAccount(unittest.TestCase):

    def setUp(self):
        self.user = UserAccount()

    def test_create_account(self):
        result = self.user.create_account("test_user", "password123")
        self.assertTrue(result)

    def test_login_success(self):
        self.user.create_account("test_user", "password123")
        result = self.user.login("test_user", "password123")
        self.assertTrue(result)

    def test_login_failure(self):
        self.user.create_account("test_user", "password123")
        result = self.user.login("test_user", "wrongpassword")
        self.assertFalse(result)

    def test_account_update(self):
        self.user.create_account("test_user", "password123")
        result = self.user.update_account("test_user", "newpassword123")
        self.assertTrue(result)

    def test_delete_account(self):
        self.user.create_account("test_user", "password123")
        result = self.user.delete_account("test_user")
        self.assertTrue(result)

    def test_account_not_found(self):
        result = self.user.login("non_existent_user", "password")
        self.assertFalse(result)

if __name__ == "__main__":
    unittest.main()